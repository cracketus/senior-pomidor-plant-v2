# Device
DEVICE_ID=balcony-edge-01
POLL_INTERVAL_SECONDS=60
MOCK_SENSORS=true
POD1_ENABLED=true
POD2_ENABLED=true

# Primary MQTT transport
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=senior-pomidor
MQTT_TLS=false

# Optional HTTP fallback
HTTP_ENABLED=false
CORE_HTTP_URL=http://192.168.1.10:8000/api/v1/edge/telemetry
HTTP_TIMEOUT_SECONDS=5

# Local telemetry storage on the edge node.
# In Docker hardware mode this is mounted to ./data/telemetry on the Raspberry Pi host.
LOCAL_STORAGE_DIR=data/telemetry
LOCAL_EVENT_DIR=data/events
LOCAL_STORAGE_MAX_AGE_DAYS=30
LOCAL_STORAGE_MAX_SIZE_MB=256

# Raspberry Pi camera photos
CAMERA_ENABLED=false
CAMERA_INTERVAL_SECONDS=3600
CAMERA_STORAGE_DIR=data/photos
CAMERA_DEVICE=/dev/video0
CAMERA_RESOLUTION=1920x1080
CAMERA_JPEG_QUALITY=95
CAMERA_PROCESS_TIMEOUT_SECONDS=20
CAMERA_SKIP_FRAMES=5
CAMERA_MAX_ATTEMPTS=3
CAMERA_MIN_SHARPNESS=6.0

# Optional photo upload to the Core server.
# Photos are uploaded as multipart/form-data; MQTT is used for telemetry only.
PHOTO_UPLOAD_ENABLED=false
PHOTO_UPLOAD_URL=http://192.168.1.10:8000/api/v1/edge/photos
PHOTO_UPLOAD_TOKEN=

# I2C addresses
ADS1115_ADDRESS=0x48
BME280_ADDRESS=0x76
BH1750_ADDRESS=0x23
MLX90615_ADDRESS=0x5A
INA219_ADDRESS=0x40

# Health control sensors and Raspberry Pi OS probes
WIFI_INTERFACE=wlan0
WIFI_PROFILE_DIR=/etc/NetworkManager/system-connections
WIFI_PREFERRED_PROFILE=
NETWORK_CHECK_HOST=1.1.1.1
NETWORK_DNS_CHECK_HOST=example.com
NETWORK_RECOVERY_STATUS_FILE=data/network-recovery/status.json
DISK_USAGE_PATH=/

# ADS1115 soil moisture channels and calibration.
# These are raw ADS1115 readings from AnalogIn.value, not volts.
ADS1115_POD1_CHANNEL=A0
ADS1115_POD2_CHANNEL=A1
ADS1115_POD1_DRY_READING=17736
ADS1115_POD1_WET_READING=7220
ADS1115_POD2_DRY_READING=17776
ADS1115_POD2_WET_READING=7220

# DS18B20 1-Wire ROM IDs
DS18B20_POD1_ROM=28-000000000001
DS18B20_POD2_ROM=28-000000000002

# Development only. Omit or set empty in production.
MAX_TICKS=
